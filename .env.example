# Achilles Nutrition — environment variables
# Copy to .env and fill in. .env is gitignored.

# ---------- Client (Vite, bundled into the browser) ----------
# Provider: backend (default) | mock | minimax (legacy, exposes key in bundle)
VITE_AI_PROVIDER=backend
# Optional: base path for the API (default /api).
# VITE_API_BASE=/api

# ---------- Server only (NO 'VITE_' prefix → never reaches the browser) ----------
PORT=8787
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_BASE_URL=https://api.minimaxi.chat
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_VISION_MODEL=MiniMax-Text-01

# ---------- Legacy direct-from-browser provider (only if VITE_AI_PROVIDER=minimax) ----------
# VITE_MINIMAX_API_KEY=
# VITE_MINIMAX_BASE_URL=/minimax
# VITE_MINIMAX_MODEL=MiniMax-M2.7
# VITE_MINIMAX_VISION_MODEL=MiniMax-Text-01
