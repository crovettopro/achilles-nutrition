{
  "name": "achilles-nutrition",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,vite -c yellow,cyan \"npm:server\" \"vite\"",
    "dev:web": "vite",
    "server": "node --env-file=.env server/index.js",
    "build": "tsc && vite build",
    "start": "NODE_ENV=production node --env-file=.env server/index.js",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.1.0",
    "playwright": "^1.61.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
